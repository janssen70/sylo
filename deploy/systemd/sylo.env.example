# Sylo config, shared by all three services (sylo-receiver, sylo-webapp,
# sylo-retention) via EnvironmentFile=/etc/sylo/sylo.env in their unit files.
# `make install` copies this file to /etc/sylo/sylo.env only if that path
# doesn't already exist -- it will not overwrite your edits on upgrade.

SYLO_DATA_DIR=/var/lib/sylo/data/raw
SYLO_INDEX_DIR=/var/lib/sylo/data/index
SYLO_APP_DB=/var/lib/sylo/data/app.sqlite3

# Password for the default "admin" account, used only on the webapp's very
# first run (when it creates that account). Uncomment and set this before
# starting sylo-webapp for the first time; otherwise a random password is
# generated and logged once -- unlike the Windows service (which has no
# console), `journalctl -u sylo-webapp` will show it.
#SYLO_ADMIN_PASSWORD=change-me
